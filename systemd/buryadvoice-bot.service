[Unit]
Description=Buryad Voice Telegram Bot
After=network.target mongod.service

[Service]
Type=simple
User=bot
WorkingDirectory=/opt/buryadvoice-bot
EnvironmentFile=/opt/buryadvoice-bot/.env
ExecStart=/opt/buryadvoice-bot/venv/bin/python bot.py
Restart=always
RestartSec=5
StandardOutput=append:/var/log/buryadvoice-bot.log
StandardError=append:/var/log/buryadvoice-bot-error.log

[Install]
WantedBy=multi-user.target